APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Vercel production (set in Vercel Dashboard → Settings → Environment Variables)
# APP_URL=https://paradit-x.com
# APP_KEY=base64:...  (run: php artisan key:generate --show)
# VERCEL_FORCE_NO_BUILD_CACHE=1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# ------------------------------------------------------------------
# PostgreSQL — Neon (production / Vercel) or Docker (local)
# SQLite does not work on Vercel serverless — use Neon or Supabase.
# Neon dashboard → Connect → copy connection string.
# ------------------------------------------------------------------
# DB_CONNECTION=pgsql
# DB_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Or set individual vars (Laravel reads DB_URL first when present):
# DB_HOST=ep-xxx.region.aws.neon.tech
# DB_PORT=5432
# DB_DATABASE=neondb
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=require

SESSION_DRIVER=database
# Vercel serverless: cookie (default in vercel.json) or database with external DB
# For Inertia/Livewire later: Upstash Redis — SESSION_DRIVER=redis, REDIS_URL=rediss://...
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------
# Stripe (test mode — set in Vercel Dashboard for production)
# ------------------------------------------------------------------
# STRIPE_KEY=pk_test_...
# STRIPE_SECRET=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------
# Docker (docker compose up)
# ------------------------------------------------------------------
# APP_URL=http://localhost:8080
# DB_CONNECTION=pgsql
# DB_HOST=pgsql
# DB_PORT=5432
# DB_DATABASE=ecomshop
# DB_USERNAME=ecomshop
# DB_PASSWORD=          # see .env.docker.example for Docker
# REDIS_HOST=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
